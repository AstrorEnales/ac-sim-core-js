{
  "name": "ac-sim-core-js",
  "author": {
    "name": "Marcel Friedrichs"
  },
  "description": "Library of different simulation methods",
  "homepage": "https://github.com/AstrorEnales/ac-sim-core-js",
  "repository": {
    "url": "https://github.com/AstrorEnales/ac-sim-core-js"
  },
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "main": "./dist/ac-sim-core-js.umd.cjs",
  "module": "./dist/ac-sim-core-js.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ac-sim-core-js.js",
      "require": "./dist/ac-sim-core-js.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "test": "vitest",
    "lint": "eslint .",
    "lint-fix": "prettier --write .",
    "version-patch": "npm version patch --no-git-tag-version",
    "version-minor": "npm version minor --no-git-tag-version",
    "version-major": "npm version major --no-git-tag-version"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@stdlib/math-base-special-erfinv": "^0.3.1",
    "decimal.js": "^10.6.0",
    "mathjs": "^15.1.1"
  },
  "peerDependencies": {
    "decimal.js": "^10.6.0"
  }
}
